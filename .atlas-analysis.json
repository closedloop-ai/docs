  "keyFeatures": [
    "Localhost HTTP gateway on port 19432 bridging ClosedLoop web app to local dev tools",
    "AI-powered coding sessions via Symphony (Claude Code integration)",
    "Git operations: branches, diffs, PRs, worktrees",
    "Sandbox directory enforcement with path-based access control",
    "Approval policy system with per-operation risk tiers (none/low/medium/high)",
    "Cloud relay connection for remote command execution",
    "Auto-update via electron-updater with in-app notifications",
    "Secure session token exchange for browser authentication",
    "macOS tray icon with connection status and pending approval count",
    "Binary path overrides for claude, gh, codex, git, python3"
  ],
  "publicApiSurface": [
    "GET /health — gateway health check and capabilities",
    "POST /gateway-auth/exchange — obtain browser session token",
    "GET /api/gateway/directories — list directory contents",
    "GET /api/gateway/files/search — search files in sandbox",
    "GET/POST /api/gateway/git/* — git actions, branches, diffs, PRs, worktrees",
    "POST /api/gateway/symphony/loop — launch AI coding session",
    "GET /api/gateway/symphony/status — session status",
    "POST /api/gateway/symphony/kill — stop a session",
    "GET /api/gateway/symphony/logs/:id — session logs",
    "GET /api/gateway/symphony/sessions — list sessions",
    "POST /api/gateway/terminal-chat — terminal chat session",
    "POST /api/gateway/ticket-chat — ticket-based chat",
    "POST /api/gateway/run-viewer-chat — run viewer chat",
    "GET /api/gateway/repos — repository configuration",
    "GET/PATCH /api/gateway/settings/binary-paths — binary path settings"
  ]
}
